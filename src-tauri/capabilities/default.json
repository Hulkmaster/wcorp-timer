{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:1420/"]
  },
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:default",
    "core:window:allow-set-decorations",
    "core:window:allow-set-always-on-top"
  ]
}

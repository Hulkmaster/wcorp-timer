{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wcorp-clocks embeded",
  "version": "0.1.8",
  "identifier": "com.hulkmaster.wcorp-clocks",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "./Microsoft.WebView2.FixedVersionRuntime.143.0.3650.96.x64/"
      }
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wcorp-clocks",
  "version": "0.2.2",
  "identifier": "com.hulkmaster.wcorp-clocks-dev",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/icon.ico"
    ]
  }
}